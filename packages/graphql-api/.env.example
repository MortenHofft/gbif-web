healthUpdateFrequency:
  enums: 30000

# Per-upstream "bulkheads". Each pool gets a process-wide concurrency limit and
# a request timeout, so a slow upstream (e.g. es-api) cannot accumulate unbounded
# in-flight work and stall the whole single-process service (which would slow
# even unrelated endpoints such as dataset search). See src/requestPools.ts.
#
#   concurrency  : max simultaneous in-flight requests for the pool, across the
#                  whole process. Omit / null / 0 / "unbounded" = no limit.
#   perRequestConcurrency : fan-out cap per GraphQL request (default 10). One
#                  query can fan out into many enQueued calls (e.g. occurrence
#                  search resolves each facet/stat field as its own search); this
#                  stops a single greedy query monopolising the shared pool.
#   maxQueueDepth: max requests allowed to wait for a slot. Beyond this, new
#                  requests are shed immediately with a 503 (backpressure) so the
#                  in-process backlog/memory stays bounded under overload. Omit =
#                  unbounded (buffer everything).
#   timeoutMs    : total budget per request (queue wait + wire). Conservative by
#                  default so only genuinely stuck requests are aborted.
#   maxSockets   : cap on concurrent TCP sockets to a single origin. Size this to
#                  the pool's concurrency (a little above it for keep-alive idle
#                  sockets), NOT to a huge number — an oversized cap lets a
#                  pathological burst consume thousands of ephemeral ports and
#                  trigger machine-wide EADDRNOTAVAIL. With a concurrency cap you
#                  never need more than ~concurrency sockets to that host.
#
# Pools: occurrence (es-api), taxon (apiv2/experimental), default (everything
# else, incl. the v1 API behind dataset search). Code defaults (if unset):
# concurrency unbounded, timeoutMs 30000, maxSockets 8000. Tune
# `occurrence.concurrency` down to enable the es-api bulkhead in production once a
# good value is found via the repro harness in tools/repro/.
requestPools:
  occurrence:
    concurrency: 100
    perRequestConcurrency: 10
    maxQueueDepth: 500
    timeoutMs: 30000
    maxSockets: 150 # ~concurrency + keep-alive headroom
  taxon:
    concurrency: 100
    perRequestConcurrency: 10
    maxQueueDepth: 500
    timeoutMs: 30000
    maxSockets: 150
  default:
    # leave the general v1 API unbounded; only timeout genuinely stuck requests.
    # maxSockets here is per-host and this agent talks to many hosts, so total
    # sockets = maxSockets x distinct hosts — keep it modest.
    timeoutMs: 30000
    maxSockets: 256

# Pre-Apollo overload guard. Sheds requests with a fast 503 BEFORE body parse /
# GraphQL validate / context build, when the process itself is saturated. This is
# the global survival net; the per-upstream pools above handle fairness. It only
# guards `guardedPaths` (never /health) and is disabled by default. See
# src/overloadGuard.ts. eventLoopDelayMs/heap are always reported on /health so
# you can tune the thresholds from the repro before enabling. Recommended start:
#   maxEventLoopDelayMs ~70 (healthy loop is <10ms; shed when it can't keep up)
#   maxHeapUsedFraction ~0.85 (pre-empt the GC death-spiral / OOM)
#   maxInFlight as a hard backstop sized to your instance.
overloadProtection:
  enabled: false
  maxEventLoopDelayMs: 70
  maxHeapUsedFraction: 0.85
  # maxInFlight: 2000
  guardedPaths:
    - /graphql
  retryAfterSeconds: 1
