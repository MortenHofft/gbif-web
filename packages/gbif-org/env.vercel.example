# =============================================================================
# gbif-org environment variables (example)
#
# Real values live in the private gbif/gbif-configuration repo:
#   https://github.com/gbif/gbif-configuration/tree/master/gbif-web/gbif-org
#
# Notes for Vercel:
# - Anything prefixed PUBLIC_ is inlined into the CLIENT bundle by Vite at BUILD
#   time, so these MUST be set in Vercel (Settings > Environment Variables) and
#   available during the build, not only at runtime.
# - The variables under REQUIRED below are validated in env.ts; the build FAILS
#   if any of them is missing.
# - Non-PUBLIC_ variables (bottom section) are server-only secrets. Never give a
#   secret a PUBLIC_ prefix.
# =============================================================================

# --- REQUIRED (build fails without these — see env.ts) ------------------------
PUBLIC_BASE_URL=
PUBLIC_TRANSLATIONS_ENTRY_ENDPOINT=
PUBLIC_GRAPHQL_ENDPOINT=
PUBLIC_FORMS_ENDPOINT=
PUBLIC_CONTENT_SEARCH=
PUBLIC_WEB_UTILS=
PUBLIC_API_V1=
PUBLIC_API_V2=
PUBLIC_TILE_API=
PUBLIC_GBIF_ORG=
PUBLIC_GRSCICOLL=
PUBLIC_CHECKLIST_BANK_WEBSITE=
PUBLIC_API_KEY_MAPTILER=
PUBLIC_ENABLED_LANGUAGES=
PUBLIC_ANALYTICS_FILES_URL=

# --- Other PUBLIC_ vars used across the app (set as needed) -------------------
PUBLIC_API=
PUBLIC_REGISTRY=
PUBLIC_HEALTH=
PUBLIC_COUNT_ENDPOINT=
PUBLIC_V1_ENDPOINT=
PUBLIC_GRAPHQL_ENDPOINT_CLIENT=
PUBLIC_GRAPHQL_ENDPOINT_SERVER=
PUBLIC_FORMS_ENDPOINT_CLIENT=
PUBLIC_FORMS_ENDPOINT_SERVER=
PUBLIC_FEEDBACK_ENDPOINT=
PUBLIC_FEEDBACK_GITHUB_REPO=
PUBLIC_TRANSLATIONS_ENTRY_ENDPOINT_CLIENT=
PUBLIC_TRANSLATIONS_ENTRY_ENDPOINT_SERVER=
PUBLIC_MAPBOX_ACCESS_TOKEN=
PUBLIC_PLAUSIBLE_DOMAIN=
PUBLIC_STATUS_PAGE_URL=
PUBLIC_TOOLS_GBIF_ORG=
PUBLIC_GBIF_ORG_CHECKLIST=
PUBLIC_STAKEHOLDERS=
PUBLIC_TEST_SITE=
PUBLIC_DEBUGGING=
# Checklist / clustering config
PUBLIC_DEFAULT_CHECKLIST_KEY=
PUBLIC_COL_CHECKLIST_KEY=
PUBLIC_CLASSIC_BACKBONE_KEY=
PUBLIC_CHECKLIST_KEY_FOR_CLUSTERING=
PUBLIC_SUPPORTED_CHECKLISTS=
PUBLIC_SUPPORTED_CHECKLISTS_FOR_DOWNLOAD=
PUBLIC_DEFAULT_VISIBLE_CHECKLISTS_FOR_DOWNLOAD=
# Feature flags
PUBLIC_DEFAULT_ENABLE_MAP_CHARTS=
PUBLIC_ENABLE_SAMPLING_EVENT_BROWSER=
# Misc keys
PUBLIC_KEYS_OBIS_NODE=
PUBLIC_KEYS_TAIWAN_PARTICIPANT=

# --- Server-only secrets (NEVER prefix with PUBLIC_) --------------------------
NODE_ENV=production
# DOMAIN is used to build OAuth callback URLs — set to your Vercel domain.
DOMAIN=
USE_SECURE_COOKIE=true
# DISABLE_HTTPS_UPGRADE=
# Encryption / signing
ENCRYPTION_KEY=
JWT_SECRET=
GRAPHQL_JWT_SECRET=
# GBIF API app credentials
APP_KEY=
APP_SECRET=
REGISTRY_API_V1=
# OAuth providers (only set the ones you want to enable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
ORCID_CLIENT_ID=
ORCID_CLIENT_SECRET=
# Logging (LOGS_DIRECTORY is for local file logging; not used on serverless)
# LOGS_DIRECTORY=
# DEBUG_LEVEL=
