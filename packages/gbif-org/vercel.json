{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": "dist/gbif/client",
  "functions": {
    "api/index.mjs": {
      "includeFiles": "{dist,public}/**",
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.mjs"
    }
  ]
}
