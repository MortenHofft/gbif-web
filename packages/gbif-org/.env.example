# =============================================================================
# gbif-org environment example
# =============================================================================
# Copy this file to `.env` (or `.env.local`) in the package root and adjust the
# values for your setup. The canonical configuration used by GBIF lives in
# `gbif-configuration/gbif-web/gbif-org`; the values below point at the GBIF
# production services so the app can be built and run out of the box.
#
# Loading is handled by Vite (https://vitejs.dev/guide/env-and-mode.html).
# Only variables prefixed with `PUBLIC_` are exposed to the client bundle, so
# NEVER prefix a secret (private API keys, OAuth secrets, ...) with `PUBLIC_`.
# =============================================================================

# -----------------------------------------------------------------------------
# Core endpoints (required — the build fails fast if any of these are missing,
# see `env.ts`)
# -----------------------------------------------------------------------------

# The public base URL the app is served from (used to build absolute links).
PUBLIC_BASE_URL=http://localhost:3000

# GraphQL API powering the site.
PUBLIC_GRAPHQL_ENDPOINT=https://graphql.gbif.org/graphql

# Translation bundles (react-intl message catalogs).
PUBLIC_TRANSLATIONS_ENTRY_ENDPOINT=https://react-components.gbif.org/lib/translations

# Forms service (feedback, dataset suggestions, ...). Served under `/forms`.
PUBLIC_FORMS_ENDPOINT=https://graphql.gbif.org/forms

# Cross-content search endpoint.
PUBLIC_CONTENT_SEARCH=https://graphql.gbif.org/unstable-api/cross-content-search

# Misc server-side helpers (polygon naming, source archives, ...). Served under
# the GraphQL API's `/unstable-api` namespace.
PUBLIC_WEB_UTILS=https://graphql.gbif.org/unstable-api

# GBIF REST APIs.
PUBLIC_API_V1=https://api.gbif.org/v1
PUBLIC_API_V2=https://api.gbif.org/v2

# Vector/raster tile server.
PUBLIC_TILE_API=https://tile.gbif.org

# Public-facing GBIF.org website (used for outbound links).
PUBLIC_GBIF_ORG=https://www.gbif.org

# GRSciColl (collections) website.
PUBLIC_GRSCICOLL=https://www.gbif.org

# ChecklistBank website.
PUBLIC_CHECKLIST_BANK_WEBSITE=https://www.checklistbank.org

# MapTiler API key (get one at https://www.maptiler.com/). A real key is only
# needed for the MapTiler basemaps to render.
PUBLIC_API_KEY_MAPTILER=YOUR_MAPTILER_KEY

# Comma separated list of enabled UI languages.
PUBLIC_ENABLED_LANGUAGES=en

# Base URL for pre-rendered analytics figures (SVG/CSV).
PUBLIC_ANALYTICS_FILES_URL=https://analytics-files.gbif.org

# -----------------------------------------------------------------------------
# Optional client endpoints / feature flags
# -----------------------------------------------------------------------------

# Registry website (ingestion history links etc.).
PUBLIC_REGISTRY=https://registry.gbif.org

# Tools subdomain (observation trends, ...).
PUBLIC_TOOLS_GBIF_ORG=https://www.gbif.org

# Feedback (GitHub issue) integration.
PUBLIC_FEEDBACK_ENDPOINT=https://graphql.gbif.org/forms/feedback
PUBLIC_FEEDBACK_GITHUB_REPO=gbif/portal-feedback

# Status / health.
PUBLIC_STATUS_PAGE_URL=https://status.gbif.org

# Mapbox token (only needed for the Mapbox-based maps/static images).
PUBLIC_MAPBOX_ACCESS_TOKEN=YOUR_MAPBOX_TOKEN

# Plausible analytics domain (leave empty to disable).
PUBLIC_PLAUSIBLE_DOMAIN=

# Set to `true` to mark this as a non-production / test deployment.
PUBLIC_TEST_SITE=false

# Set to `true` to enable extra client-side debug logging.
PUBLIC_DEBUGGING=false

# Set to `enabled` to expose the experimental sampling-event browser.
PUBLIC_ENABLE_SAMPLING_EVENT_BROWSER=disabled

# -----------------------------------------------------------------------------
# Checklist configuration
# -----------------------------------------------------------------------------
# GBIF backbone taxonomy key.
PUBLIC_DEFAULT_CHECKLIST_KEY=d7dddbf4-2cf0-4f39-9b2a-bb099caae36c
PUBLIC_CLASSIC_BACKBONE_KEY=d7dddbf4-2cf0-4f39-9b2a-bb099caae36c
PUBLIC_CHECKLIST_KEY_FOR_CLUSTERING=d7dddbf4-2cf0-4f39-9b2a-bb099caae36c
# Catalogue of Life checklist key.
PUBLIC_COL_CHECKLIST_KEY=7ddf754f-d193-4cc9-b351-99906754a03b
# Known publisher keys used for special-casing in the UI.
PUBLIC_ISSG_PUBLISHER_KEY=cdef28b1-db4e-4c58-aa71-3c5238c2d0b5

# -----------------------------------------------------------------------------
# Server-only configuration (NOT exposed to the client). These are only needed
# when running the SSR server (`npm run start`) — not for building the client.
# -----------------------------------------------------------------------------

# HTTP port and node runtime mode.
PORT=3000
NODE_ENV=production

# Where rotating server logs are written.
LOGS_DIRECTORY=./logs
DEBUG_LEVEL=WARN

# Cookie / TLS behaviour.
USE_SECURE_COOKIE=false
DISABLE_HTTPS_UPGRADE=true
DOMAIN=localhost

# App identity used against the GBIF registry directory.
APP_KEY=gbif.app.it
APP_SECRET=YOUR_APP_SECRET

# Secrets for signing/verifying JWTs and encrypting cookies.
JWT_SECRET=YOUR_JWT_SECRET
GRAPHQL_JWT_SECRET=YOUR_GRAPHQL_JWT_SECRET
ENCRYPTION_KEY=YOUR_ENCRYPTION_KEY

# OAuth providers (login). Leave blank to disable a given provider.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ORCID_CLIENT_ID=
ORCID_CLIENT_SECRET=

# Comma separated lists for the runtime admin endpoint (POST /admin/settings).
ADMIN_USERS=
ADMIN_GRAPHQL_NODES=
ADMIN_ES_API_NODES=
